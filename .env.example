# Public Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase credential. Never expose this value to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe server credentials
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Public application URL used for invitations and Stripe redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Business timezone used for order availability checks
APP_TIME_ZONE=America/Denver
